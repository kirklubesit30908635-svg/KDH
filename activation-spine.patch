+import assert from "node:assert/strict";
+import test from "node:test";
+import { readFileSync, existsSync } from "node:fs";
+import { join } from "node:path";
+
+function readFile(p: string): string {
+  const full = join(process.cwd(), p);
+  return existsSync(full) ? readFileSync(full, "utf-8") : "";
+}
+
+const migration = readFile("supabase/migrations/20260328120000_activation_spine.sql");
+const middleware = readFile("src/middleware.ts");
+const statusRoute = readFile("src/app/api/customer/status/route.ts");
+const activatePage = readFile("src/app/activate/page.tsx");
+const connectPage = readFile("src/app/activate/connect/page.tsx");
+const verifyPage = readFile("src/app/activate/verify/page.tsx");
+const settingsPage = readFile("src/app/command/settings/page.tsx");
+const provisionTs = readFile("src/lib/kernel/provisionFromStripe.ts");
+
+// === Migration: activation_state table ===
+
+test("migration: creates core.activation_state table", () => {
+  assert.ok(migration.includes("CREATE TABLE IF NOT EXISTS core.activation_state"));
+});
+
+test("migration: has all required spine fields", () => {
+  const required = [
+    "workspace_id", "stripe_customer_id", "stripe_subscription_id",
+    "subscription_status", "billing_status", "plan_key", "engine_key",
+    "entitlement_key", "governance_key", "provisioning_status",
+    "membership_status", "stripe_connection_status", "enforcement_status",
+    "events_received", "obligations_open", "receipts_issued",
+    "first_event_at", "last_event_at", "last_receipt_at",
+    "next_action", "activated_at",
+  ];
+  for (const field of required) {
+    assert.ok(migration.includes(field), `Missing field: ${field}`);
+  }
+});
+
+test("migration: next_action has correct state enum", () => {
+  assert.ok(migration.includes("provisioning"));
+  assert.ok(migration.includes("connect_stripe"));
+  assert.ok(migration.includes("wait_for_first_event"));
+  assert.ok(migration.includes("open_dashboard"));
+});
+
+test("migration: enforcement_status has correct enum", () => {
+  assert.ok(migration.includes("not_live"));
+  assert.ok(migration.includes("first_event_seen"));
+  assert.ok(migration.includes("'live'"));
+});
+
+// === Migration: auto-create trigger ===
+
+test("migration: auto-creates activation on workspace insert", () => {
+  assert.ok(migration.includes("trg_create_activation_state"));
+});
+
+test("migration: backfills existing workspaces", () => {
+  assert.ok(migration.includes("Backfill for existing workspaces"));
+});
+
+// === Migration: resolve_activation_state ===
+
+test("migration: creates resolve_activation_state resolver", () => {
+  assert.ok(migration.includes("api.resolve_activation_state"));
+});
+
+test("migration: resolver computes live counts", () => {
+  assert.ok(migration.includes("v_events"));
+  assert.ok(migration.includes("v_open"));
+  assert.ok(migration.includes("v_receipts"));
+});
+
+test("migration: resolver derives next_action from state", () => {
+  assert.ok(migration.includes("v_next :="));
+});
+
+test("migration: resolver persists computed state back", () => {
+  assert.ok(migration.includes("UPDATE core.activation_state"));
+});
+
+test("migration: resolver returns canonical activation JSON", () => {
+  assert.ok(migration.includes("jsonb_build_object"));
+  assert.ok(migration.includes("'next_action'"));
+  assert.ok(migration.includes("'enforcement_status'"));
+});
+
+// === Migration: RPCs ===

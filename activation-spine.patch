@@ -0,0 +1,229 @@
+"use client";
+
+import { useCallback, useEffect, useState } from "react";
+import { useRouter } from "next/navigation";
+import {
+  ArrowRight,
+  CheckCircle2,
+  Circle,
+  Loader2,
+  Radio,
+  ShieldCheck,
+  Sparkles,
+} from "lucide-react";
+
+const STEPS = [
+  { key: "profile", label: "Business Profile" },
+  { key: "connect", label: "Connect Billing" },
+  { key: "verify", label: "Verify Enforcement" },
+];
+
+function StepIndicator({ current }: { current: number }) {
+  return (
+    <div className="flex items-center gap-3">
+      {STEPS.map((step, i) => (
+        <div key={step.key} className="flex items-center gap-2">
+          {i < current ? (
+            <CheckCircle2 className="h-5 w-5 text-emerald-400" />
+          ) : i === current ? (
+            <div className="h-5 w-5 rounded-full border-2 border-cyan-400 bg-cyan-400/20" />
+          ) : (
+            <Circle className="h-5 w-5 text-slate-600" />
+          )}
+          <span
+            className={`text-sm ${i === current ? "text-white font-medium" : "text-slate-500"}`}
+          >
+            {step.label}
+          </span>
+          {i < STEPS.length - 1 && (
+            <div className="mx-2 h-px w-8 bg-white/10" />
+          )}
+        </div>
+      ))}
+    </div>
+  );
+}
+
+type VerifyState = "checking" | "waiting" | "verified" | "error";
+
+export default function VerifyPage() {
+  const router = useRouter();
+  const [state, setState] = useState<VerifyState>("checking");
+  const [obligationCount, setObligationCount] = useState(0);
+  const [error, setError] = useState<string | null>(null);
+
+  const checkEnforcement = useCallback(async () => {
+    try {
+      const res = await fetch("/api/customer/status", { cache: "no-store" });
+      const data = await res.json();
+      const activation = data.activation;
+
+      if (activation && (activation.enforcement_status === "live" || activation.enforcement_status === "first_event_seen")) {
+        setObligationCount(activation.obligations_open ?? 1);
+        setState("verified");
+      } else {
+        setState("waiting");
+      }
+    } catch (err) {
+      setError(err instanceof Error ? err.message : "Check failed");
+      setState("error");
+    }
+  }, []);
+
+  useEffect(() => {
+    void checkEnforcement();
+
+    // Poll every 5 seconds if waiting
+    const interval = setInterval(() => {
+      if (state === "waiting" || state === "checking") {
+        void checkEnforcement();
+      }
+    }, 5000);
+
+    return () => clearInterval(interval);
+  }, [checkEnforcement, state]);
+
+  async function handleActivate() {
+    try {
+      await fetch("/api/onboard/activate", { method: "POST" });
+      router.push("/command");
+    } catch {
+      router.push("/command");
+    }
+  }
+
+  function handleSkip() {
+    void handleActivate();
+  }
+
+  return (
+    <div className="min-h-screen bg-[#071018] text-slate-100">
+      <div className="pointer-events-none fixed inset-0 overflow-hidden">
+        <div className="absolute left-[-14%] top-[-8%] h-[26rem] w-[26rem] rounded-full bg-cyan-300/10 blur-3xl" />
+        <div className="absolute right-[-10%] top-[8%] h-[28rem] w-[28rem] rounded-full bg-amber-300/10 blur-3xl" />
+      </div>
+
+      <div className="relative mx-auto max-w-2xl px-4 py-16 sm:px-6">
+        <div className="text-center">
+          <div className="mx-auto grid h-14 w-14 place-items-center rounded-2xl border border-white/10 bg-white/[0.04] text-lg font-semibold text-white shadow-[0_12px_30px_rgba(0,0,0,0.22)]">
+            AK
+          </div>
+          <h1 className="mt-6 text-3xl font-semibold tracking-tight text-white">
+            {state === "verified"
+              ? "Enforcement is live"
+              : "Verifying enforcement"}
+          </h1>
+          <p className="mt-3 text-sm text-slate-400">
+            {state === "verified"
+              ? "AutoKirk received your first revenue event and created an obligation. Your workspace is protected."
+              : "AutoKirk is listening for your first revenue event. Once received, enforcement activates automatically."}
+          </p>
+        </div>
+
+        <div className="mt-8 flex justify-center">
+          <StepIndicator current={2} />
+        </div>
+
+        <div className="mt-10 rounded-[1.6rem] border border-white/10 bg-[linear-gradient(180deg,rgba(13,24,37,0.92),rgba(8,16,26,0.85))] p-8 shadow-[0_20px_60px_rgba(0,0,0,0.2)]">
+          {state === "checking" && (
+            <div className="flex flex-col items-center gap-4 py-8">
+              <Loader2 className="h-8 w-8 animate-spin text-cyan-400" />
+              <div className="text-sm text-slate-400">
+                Checking enforcement status…
+              </div>
+            </div>
+          )}
+
+          {state === "waiting" && (
+            <div className="space-y-6">
+              <div className="flex flex-col items-center gap-4 py-4">
+                <div className="relative">
+                  <Radio className="h-10 w-10 text-amber-400" />
+                  <div className="absolute -right-1 -top-1 h-3 w-3 animate-pulse rounded-full bg-amber-400" />
+                </div>
+                <div className="text-center">
+                  <div className="text-lg font-medium text-white">
+                    Listening for events
+                  </div>
+                  <div className="mt-1 text-sm text-slate-400">
+                    Make a payment or trigger a billing event in your Stripe
+                    account. AutoKirk will detect it automatically.
+                  </div>
+                </div>
+              </div>
+
+              <div className="rounded-xl border border-amber-300/20 bg-amber-300/5 p-4 text-sm text-amber-200">
+                No events received yet. If you connected Stripe, try processing a
+                test payment. Otherwise, you can skip this step and start exploring.
+              </div>
+
+              <button
+                onClick={handleSkip}
+                className="flex w-full items-center justify-center gap-2 rounded-2xl border border-white/10 bg-white/[0.04] px-4 py-3 text-sm text-slate-300 transition hover:border-white/20 hover:bg-white/[0.08]"
+              >
+                Skip and enter workspace
+                <ArrowRight className="h-4 w-4" />
+              </button>
+            </div>
+          )}
+
+          {state === "verified" && (
+            <div className="space-y-6">
+              <div className="flex flex-col items-center gap-4 py-4">
+                <div className="grid h-16 w-16 place-items-center rounded-full border border-emerald-400/30 bg-emerald-400/10">
+                  <ShieldCheck className="h-8 w-8 text-emerald-400" />
+                </div>
+                <div className="text-center">
+                  <div className="text-lg font-medium text-white">
+                    Enforcement confirmed
+                  </div>
+                  <div className="mt-1 text-sm text-slate-400">
+                    {obligationCount} obligation{obligationCount !== 1 ? "s" : ""}{" "}
+                    created from your revenue events. AutoKirk is tracking your
+                    revenue integrity.
+                  </div>
+                </div>
+              </div>
+
+              <div className="rounded-xl border border-emerald-300/20 bg-emerald-300/5 p-4">
+                <div className="flex items-start gap-3">
+                  <Sparkles className="mt-0.5 h-5 w-5 shrink-0 text-emerald-400" />
+                  <div className="text-sm text-emerald-200">
+                    Your workspace is now active. Every payment event creates an
+                    obligation. Every operator action produces a receipt. The
+                    integrity score reflects reality.
+                  </div>
+                </div>
+              </div>
+
+              <button
+                onClick={handleActivate}
+                className="flex w-full items-center justify-center gap-2 rounded-2xl border border-transparent bg-white px-4 py-3 text-sm font-medium text-slate-950 transition hover:bg-slate-100"
+              >
+                Enter your workspace
+                <ArrowRight className="h-4 w-4" />
+              </button>
+            </div>
+          )}
+
+          {state === "error" && (
+            <div className="space-y-6">
+              <div className="rounded-xl border border-rose-300/20 bg-rose-300/10 p-4 text-sm text-rose-200">
+                {error ?? "Something went wrong checking enforcement status."}
+              </div>
+              <button
+                onClick={() => {
+                  setState("checking");
+                  void checkEnforcement();
+                }}
+                className="flex w-full items-center justify-center gap-2 rounded-2xl border border-white/10 bg-white/[0.04] px-4 py-3 text-sm text-slate-300 transition hover:border-white/20"
+              >
+                Retry
+              </button>
+            </div>
+          )}
+        </div>
+      </div>
+    </div>
+  );
+}

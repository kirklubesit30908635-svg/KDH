{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Supabase Local (autokirk-kernel)",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "supabase start; tail -f /dev/null"],
      "port": 54321,
      "autoPort": false
    },
    {
      "name": "Next.js Dev (autokirk-kernel)",
      "runtimeExecutable": "C:/Windows/System32/cmd.exe",
      "runtimeArgs": ["/c", "npm", "run", "dev"],
      "port": 3000,
      "autoPort": true
    }
  ]
}

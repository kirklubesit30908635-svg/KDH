+"use client";
+
+import { useState } from "react";
+import { useRouter } from "next/navigation";
+import {
+  ArrowRight,
+  CheckCircle2,
+  Circle,
+  CreditCard,
+  ExternalLink,
+  Loader2,
+  Shield,
+} from "lucide-react";
+
+const STEPS = [
+  { key: "profile", label: "Business Profile" },
+  { key: "connect", label: "Connect Billing" },
+  { key: "verify", label: "Verify Enforcement" },
+];
+
+function StepIndicator({ current }: { current: number }) {
+  return (
+    <div className="flex items-center gap-3">
+      {STEPS.map((step, i) => (
+        <div key={step.key} className="flex items-center gap-2">
+          {i < current ? (
+            <CheckCircle2 className="h-5 w-5 text-emerald-400" />
+          ) : i === current ? (
+            <div className="h-5 w-5 rounded-full border-2 border-cyan-400 bg-cyan-400/20" />
+          ) : (
+            <Circle className="h-5 w-5 text-slate-600" />
+          )}
+          <span
+            className={`text-sm ${i === current ? "text-white font-medium" : "text-slate-500"}`}
+          >
+            {step.label}
+          </span>
+          {i < STEPS.length - 1 && (
+            <div className="mx-2 h-px w-8 bg-white/10" />
+          )}
+        </div>
+      ))}
+    </div>
+  );
+}
+
+export default function ConnectPage() {
+  const router = useRouter();
+  const [connecting, setConnecting] = useState(false);
+  const [skipping, setSkipping] = useState(false);
+
+  async function handleConnect() {
+    setConnecting(true);
+    // In production, this would initiate Stripe Connect OAuth.
+    // For now, redirect to a Stripe Connect onboarding URL.
+    // The return URL would be /api/stripe/connect/callback
+    try {
+      const res = await fetch("/api/onboard/connect-url", {
+        method: "POST",
+      });
+      const data = await res.json();
+      if (data.url) {
+        window.location.href = data.url;
+      } else {
+        // If Connect isn't configured yet, skip to verify
+        router.push("/activate/verify");
+      }
+    } catch {
+      router.push("/activate/verify");
+    }
+  }
+
+  async function handleSkip() {
+    setSkipping(true);
+    // For founder/demo: skip Connect and go to verify
+    router.push("/activate/verify");
+  }
+
+  return (
+    <div className="min-h-screen bg-[#071018] text-slate-100">
+      <div className="pointer-events-none fixed inset-0 overflow-hidden">
+        <div className="absolute left-[-14%] top-[-8%] h-[26rem] w-[26rem] rounded-full bg-cyan-300/10 blur-3xl" />
+        <div className="absolute right-[-10%] top-[8%] h-[28rem] w-[28rem] rounded-full bg-amber-300/10 blur-3xl" />
+      </div>
+
+      <div className="relative mx-auto max-w-2xl px-4 py-16 sm:px-6">
+        <div className="text-center">
+          <div className="mx-auto grid h-14 w-14 place-items-center rounded-2xl border border-white/10 bg-white/[0.04] text-lg font-semibold text-white shadow-[0_12px_30px_rgba(0,0,0,0.22)]">
+            AK
+          </div>
+          <h1 className="mt-6 text-3xl font-semibold tracking-tight text-white">
+            Connect your billing source
+          </h1>
+          <p className="mt-3 text-sm text-slate-400">
+            AutoKirk ingests your Stripe events to create obligations and track
+            enforcement. Connect your Stripe account so AutoKirk can watch your
+            revenue.
+          </p>
+        </div>
+
+        <div className="mt-8 flex justify-center">
+          <StepIndicator current={1} />
+        </div>
+
+        <div className="mt-10 rounded-[1.6rem] border border-white/10 bg-[linear-gradient(180deg,rgba(13,24,37,0.92),rgba(8,16,26,0.85))] p-8 shadow-[0_20px_60px_rgba(0,0,0,0.2)]">
+          <div className="flex items-center gap-3 border-b border-white/10 pb-4">
+            <CreditCard className="h-5 w-5 text-cyan-400" />
+            <span className="text-[11px] font-semibold uppercase tracking-[0.3em] text-slate-500">
+              Stripe Connect
+            </span>
+          </div>
+
+          <div className="mt-6 space-y-6">
+            <div className="rounded-xl border border-white/10 bg-white/[0.02] p-5">
+              <div className="flex items-start gap-4">
+                <Shield className="mt-0.5 h-5 w-5 shrink-0 text-emerald-400" />
+                <div>
+                  <div className="text-sm font-medium text-white">
+                    Secure OAuth connection
+                  </div>
+                  <div className="mt-1 text-sm text-slate-400">
+                    AutoKirk uses Stripe Connect to read your payment events.
+                    We never store your Stripe credentials — the connection uses
+                    OAuth with read-only event access.
+                  </div>
+                </div>
+              </div>
+            </div>
+
+            <div className="rounded-xl border border-white/10 bg-white/[0.02] p-5">
+              <div className="text-sm text-slate-300">
+                Once connected, AutoKirk will:
+              </div>
+              <ul className="mt-3 space-y-2 text-sm text-slate-400">
+                <li className="flex items-center gap-2">
+                  <CheckCircle2 className="h-4 w-4 text-emerald-400" />
+                  Receive your payment events in real time
+                </li>
+                <li className="flex items-center gap-2">
+                  <CheckCircle2 className="h-4 w-4 text-emerald-400" />
+                  Create obligations for every revenue-affecting event
+                </li>
+                <li className="flex items-center gap-2">
+                  <CheckCircle2 className="h-4 w-4 text-emerald-400" />
+                  Track enforcement with receipted proof
+                </li>
+              </ul>
+            </div>
+
+            <button
+              onClick={handleConnect}
+              disabled={connecting}
+              className="flex w-full items-center justify-center gap-2 rounded-2xl border border-transparent bg-[#635bff] px-4 py-3 text-sm font-medium text-white transition hover:bg-[#7a73ff] disabled:opacity-50"
+            >
+              {connecting ? (
+                <Loader2 className="h-4 w-4 animate-spin" />
+              ) : (
+                <>
+                  Connect with Stripe
+                  <ExternalLink className="h-4 w-4" />
+                </>
+              )}
+            </button>
+
+            <button
+              onClick={handleSkip}
+              disabled={skipping}
+              className="flex w-full items-center justify-center gap-2 rounded-2xl border border-white/10 bg-white/[0.04] px-4 py-3 text-sm text-slate-300 transition hover:border-white/20 hover:bg-white/[0.08]"
+            >
+              {skipping ? (
+                <Loader2 className="h-4 w-4 animate-spin" />
+              ) : (
+                <>
+                  Skip for now
+                  <ArrowRight className="h-4 w-4" />
+                </>
+              )}
+            </button>
+          </div>
+        </div>
+      </div>
+    </div>
+  );
+}

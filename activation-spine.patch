+"use client";
+
+import { useState } from "react";
+import { useRouter } from "next/navigation";
+import { createBrowserSupabaseClient } from "@/lib/supabase/supabaseBrowser";
+import {
+  Building2,
+  ArrowRight,
+  CheckCircle2,
+  Circle,
+  Loader2,
+} from "lucide-react";
+
+const BUSINESS_TYPES = [
+  { value: "marine_dealership", label: "Marine Dealership" },
+  { value: "auto_dealership", label: "Auto Dealership" },
+  { value: "equipment_dealer", label: "Equipment Dealer" },
+  { value: "service_provider", label: "Service Provider" },
+  { value: "other", label: "Other" },
+];
+
+const STEPS = [
+  { key: "profile", label: "Business Profile" },
+  { key: "connect", label: "Connect Billing" },
+  { key: "verify", label: "Verify Enforcement" },
+];
+
+function StepIndicator({ current }: { current: number }) {
+  return (
+    <div className="flex items-center gap-3">
+      {STEPS.map((step, i) => (
+        <div key={step.key} className="flex items-center gap-2">
+          {i < current ? (
+            <CheckCircle2 className="h-5 w-5 text-emerald-400" />
+          ) : i === current ? (
+            <div className="h-5 w-5 rounded-full border-2 border-cyan-400 bg-cyan-400/20" />
+          ) : (
+            <Circle className="h-5 w-5 text-slate-600" />
+          )}
+          <span
+            className={`text-sm ${i === current ? "text-white font-medium" : "text-slate-500"}`}
+          >
+            {step.label}
+          </span>
+          {i < STEPS.length - 1 && (
+            <div className="mx-2 h-px w-8 bg-white/10" />
+          )}
+        </div>
+      ))}
+    </div>
+  );
+}
+
+export default function OnboardPage() {
+  const router = useRouter();
+  const [businessName, setBusinessName] = useState("");
+  const [businessType, setBusinessType] = useState("");
+  const [saving, setSaving] = useState(false);
+  const [error, setError] = useState<string | null>(null);
+
+  async function handleSubmit() {
+    if (!businessName.trim()) {
+      setError("Business name is required");
+      return;
+    }
+
+    setSaving(true);
+    setError(null);
+
+    try {
+      const res = await fetch("/api/onboard/profile", {
+        method: "POST",
+        headers: { "Content-Type": "application/json" },
+        body: JSON.stringify({
+          business_name: businessName.trim(),
+          business_type: businessType || null,
+        }),
+      });
+
+      const data = await res.json();
+      if (!res.ok) throw new Error(data.error ?? "Failed to save profile");
+
+      router.push("/activate/connect");
+    } catch (err) {
+      setError(err instanceof Error ? err.message : "Something went wrong");
+    } finally {
+      setSaving(false);
+    }
+  }
+
+  return (
+    <div className="min-h-screen bg-[#071018] text-slate-100">
+      <div className="pointer-events-none fixed inset-0 overflow-hidden">
+        <div className="absolute left-[-14%] top-[-8%] h-[26rem] w-[26rem] rounded-full bg-cyan-300/10 blur-3xl" />
+        <div className="absolute right-[-10%] top-[8%] h-[28rem] w-[28rem] rounded-full bg-amber-300/10 blur-3xl" />
+      </div>
+
+      <div className="relative mx-auto max-w-2xl px-4 py-16 sm:px-6">
+        <div className="text-center">
+          <div className="mx-auto grid h-14 w-14 place-items-center rounded-2xl border border-white/10 bg-white/[0.04] text-lg font-semibold text-white shadow-[0_12px_30px_rgba(0,0,0,0.22)]">
+            AK
+          </div>
+          <h1 className="mt-6 text-3xl font-semibold tracking-tight text-white">
+            Set up your workspace
+          </h1>
+          <p className="mt-3 text-sm text-slate-400">
+            AutoKirk provisions a governed operational workspace for your
+            business. Every revenue event, obligation, and resolution is tracked
+            with receipted proof.
+          </p>
+        </div>
+
+        <div className="mt-8 flex justify-center">
+          <StepIndicator current={0} />
+        </div>
+
+        <div className="mt-10 rounded-[1.6rem] border border-white/10 bg-[linear-gradient(180deg,rgba(13,24,37,0.92),rgba(8,16,26,0.85))] p-8 shadow-[0_20px_60px_rgba(0,0,0,0.2)]">
+          <div className="flex items-center gap-3 border-b border-white/10 pb-4">
+            <Building2 className="h-5 w-5 text-cyan-400" />
+            <span className="text-[11px] font-semibold uppercase tracking-[0.3em] text-slate-500">
+              Business Profile
+            </span>
+          </div>
+
+          <div className="mt-6 space-y-5">
+            <div>
+              <label className="mb-2 block text-sm text-slate-300">
+                Business name
+              </label>
+              <input
+                type="text"
+                value={businessName}
+                onChange={(e) => setBusinessName(e.target.value)}
+                placeholder="e.g. Old Salt Marine"
+                className="w-full rounded-2xl border border-white/10 bg-white/[0.04] px-4 py-3 text-sm text-white outline-none transition placeholder:text-slate-500 focus:border-cyan-300/25 focus:bg-white/[0.06]"
+              />
+            </div>
+
+            <div>
+              <label className="mb-2 block text-sm text-slate-300">
+                Business type
+              </label>
+              <select
+                value={businessType}
+                onChange={(e) => setBusinessType(e.target.value)}
+                className="w-full rounded-2xl border border-white/10 bg-[#0b1520] px-4 py-3 text-sm text-white outline-none transition focus:border-cyan-300/25"
+              >
+                <option value="">Select type…</option>
+                {BUSINESS_TYPES.map((t) => (
+                  <option key={t.value} value={t.value}>
+                    {t.label}
+                  </option>
+                ))}
+              </select>
+            </div>
+
+            {error && (
+              <div className="rounded-xl border border-rose-300/20 bg-rose-300/10 px-4 py-3 text-sm text-rose-200">
+                {error}
+              </div>
+            )}
+
+            <button
+              onClick={handleSubmit}
+              disabled={saving || !businessName.trim()}
+              className="flex w-full items-center justify-center gap-2 rounded-2xl border border-transparent bg-white px-4 py-3 text-sm font-medium text-slate-950 transition hover:bg-slate-100 disabled:cursor-not-allowed disabled:opacity-50"
+            >
+              {saving ? (
+                <Loader2 className="h-4 w-4 animate-spin" />
+              ) : (
+                <>
+                  Continue
+                  <ArrowRight className="h-4 w-4" />
+                </>
+              )}
+            </button>
+          </div>
+        </div>
+
+        <div className="mt-6 text-center text-xs text-slate-600">
+          AutoKirk provisions governed workspaces from paid billing accounts.
+          Stripe is the billing trigger — AutoKirk owns the activation path.
+        </div>
+      </div>
+    </div>
+  );
+}

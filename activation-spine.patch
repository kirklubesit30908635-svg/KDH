diff --git a/src/middleware.ts b/src/middleware.ts
new file mode 100644
index 0000000..3af138e
--- /dev/null
+++ b/src/middleware.ts
@@ -0,0 +1,153 @@
+import { NextResponse, type NextRequest } from "next/server";
+import { createServerClient } from "@supabase/ssr";
+
+// Routes that never require auth
+const PUBLIC = new Set(["/", "/login", "/auth/callback"]);
+
+// Routes that are part of the activation flow (auth required, but no activation gate)
+const ACTIVATION_ROUTES = new Set([
+  "/activate",
+  "/activate/connect",
+  "/activate/verify",
+]);
+
+function isPublic(pathname: string) {
+  return PUBLIC.has(pathname) || pathname.startsWith("/api/stripe/");
+}
+
+function isActivationRoute(pathname: string) {
+  return ACTIVATION_ROUTES.has(pathname);
+}
+
+function isApiRoute(pathname: string) {
+  return pathname.startsWith("/api/");
+}
+
+// Map next_action → destination route
+function routeForAction(action: string): string {
+  switch (action) {
+    case "provisioning":
+      return "/activate";
+    case "connect_stripe":
+      return "/activate/connect";
+    case "wait_for_first_event":
+      return "/activate/verify";
+    case "open_dashboard":
+      return "/command";
+    default:
+      return "/activate";
+  }
+}
+
+export async function middleware(request: NextRequest) {
+  const { pathname } = request.nextUrl;
+
+  // Public routes pass through
+  if (isPublic(pathname)) {
+    return NextResponse.next();
+  }
+
+  // API routes: only check auth, don't redirect
+  if (isApiRoute(pathname)) {
+    return NextResponse.next();
+  }
+
+  // Build auth-aware response
+  const response = NextResponse.next();
+  const supabase = createServerClient(
+    process.env.NEXT_PUBLIC_SUPABASE_URL!,
+    process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!,
+    {
+      cookies: {
+        getAll() {
+          return request.cookies.getAll();
+        },
+        setAll(cookiesToSet) {
+          cookiesToSet.forEach(({ name, value, options }) => {
+            response.cookies.set(name, value, options);
+          });
+        },
+      },
+    }
+  );
+
+  const {
+    data: { user },
+  } = await supabase.auth.getUser();
+
+  // No session → login
+  if (!user) {
+    const loginUrl = new URL("/login", request.url);
+    loginUrl.searchParams.set("next", pathname);
+    return NextResponse.redirect(loginUrl);
+  }
+
+  // Founder bypass — full access, no activation checks
+  const founderEmail = process.env.FOUNDER_EMAIL ?? "kirklubesit30908635@gmail.com";
+  if (user.email === founderEmail) {
+    return response;
+  }
+
+  // Activation routes: just verify auth (already done above)
+  if (isActivationRoute(pathname)) {
+    return response;
+  }
+
+  // Product routes: check activation spine
+  const { data: operator } = await supabase
+    .schema("core")
+    .from("operators")
+    .select("id")
+    .eq("auth_uid", user.id)
+    .maybeSingle();
+
+  if (!operator) {
+    return NextResponse.redirect(new URL("/activate", request.url));
+  }
+
+  const { data: memberships } = await supabase
+    .schema("core")
+    .from("memberships")
+    .select("workspace_id")
+    .eq("operator_id", operator.id)
+    .limit(1);
+
+  if (!memberships || memberships.length === 0) {
+    return NextResponse.redirect(new URL("/activate", request.url));
+  }
+
+  const workspaceId = memberships[0].workspace_id;
+
+  const { data: activation } = await supabase
+    .schema("core")
+    .from("activation_state")
+    .select("next_action")
+    .eq("workspace_id", workspaceId)
+    .maybeSingle();
+
+  if (!activation) {
+    return NextResponse.redirect(new URL("/activate", request.url));
+  }
+
+  // Route from the spine
+  const correctRoute = routeForAction(activation.next_action);
+
+  // Already at correct location → pass through
+  if (pathname === correctRoute || pathname.startsWith(correctRoute + "/")) {
+    return response;
+  }
+
+  // Spine says dashboard and user is anywhere in /command → allow
+  if (activation.next_action === "open_dashboard" && pathname.startsWith("/command")) {
+    return response;
+  }
+
+  // Redirect to correct activation step
+  return NextResponse.redirect(new URL(correctRoute, request.url));
+}
+
+export const config = {
+  matcher: [
+    "/((?!_next/static|_next/image|favicon.ico|logo-coin.png|logo-mark.png|.*\\.(?:svg|png|jpg|jpeg|gif|webp)$).*)",
+  ],
+};
diff --git a/supabase/migrations/20260328120000_activation_spine.sql b/supabase/migrations/20260328120000_activation_spine.sql
new file mode 100644
index 0000000..82968a1
--- /dev/null
+++ b/supabase/migrations/20260328120000_activation_spine.sql
@@ -0,0 +1,385 @@
+-- ============================================================
+-- 20260328120000_activation_spine.sql
+-- ============================================================
+-- AUTOKIRK ACTIVATION SPINE
+--
+-- One canonical activation record per customer workspace.
+-- Every screen reads from this. No scattered truth.
+--
+-- State machine:
+--   paid → provisioning → workspace_ready → connect_required
+--   → connected → first_event_seen → live
+--
+-- The activation spine is the source of truth for:
+--   - post-checkout success
+--   - post-login redirect
+--   - onboarding progression
+--   - dashboard top state
+--   - upgrade/recovery messaging
+--
+-- KERNEL AUDIT:
+--   1. Obligation: activation updates tracked via governed RPCs
+--   2. Receipt: state transitions logged
+--   3. Governed: All mutations via api.* RPCs
+--   4. Leakage: No — activation state prevents premature access
+--   5. Isolation: workspace_id scoped, RLS enforced
+-- ============================================================
+
+BEGIN;
+
+-- ------------------------------------
+-- 1. Activation state table
+-- ------------------------------------
+
+CREATE TABLE IF NOT EXISTS core.activation_state (
+  id                       uuid PRIMARY KEY DEFAULT gen_random_uuid(),
+  workspace_id             uuid NOT NULL UNIQUE REFERENCES core.workspaces(id),
+
+  -- Billing identity
+  stripe_customer_id       text,
+  stripe_subscription_id   text,
+
+  -- Commercial state
+  subscription_status      text NOT NULL DEFAULT 'inactive'
+    CHECK (subscription_status IN ('active', 'trialing', 'past_due', 'canceled', 'inactive')),
+  billing_status           text NOT NULL DEFAULT 'unpaid'
+    CHECK (billing_status IN ('paid', 'unpaid', 'past_due', 'refunded')),
+  plan_key                 text NOT NULL DEFAULT 'core_enforcement',
+  engine_key               text NOT NULL DEFAULT 'engine_one',
+  entitlement_key          text NOT NULL DEFAULT 'autokirk_core_access',
+  governance_key            text NOT NULL DEFAULT 'sovereign',
+
+  -- Provisioning state
+  provisioning_status      text NOT NULL DEFAULT 'pending'
+    CHECK (provisioning_status IN ('pending', 'provisioning', 'workspace_ready', 'failed')),
+  membership_status        text NOT NULL DEFAULT 'pending'
+    CHECK (membership_status IN ('active', 'pending', 'suspended')),
+
+  -- Connection state
+  stripe_connection_status text NOT NULL DEFAULT 'not_connected'
+    CHECK (stripe_connection_status IN ('not_connected', 'connected', 'disconnected', 'error')),
+  stripe_connect_account_id text,
+
+  -- Enforcement state
+  enforcement_status       text NOT NULL DEFAULT 'not_live'
+    CHECK (enforcement_status IN ('not_live', 'first_event_seen', 'live', 'suspended')),
+
+  -- Activity tracking
+  events_received          int NOT NULL DEFAULT 0,
+  obligations_open         int NOT NULL DEFAULT 0,
+  receipts_issued          int NOT NULL DEFAULT 0,
+  first_event_at           timestamptz,
+  last_event_at            timestamptz,
+  last_receipt_at          timestamptz,
+
+  -- Progression
+  next_action              text NOT NULL DEFAULT 'provisioning'
+    CHECK (next_action IN (
+      'provisioning',
+      'connect_stripe',
+      'wait_for_first_event',
+      'open_dashboard'
+    )),
+
+  -- Business profile
+  business_name            text,
+  business_type            text,
+
+  -- Timestamps
+  activated_at             timestamptz,
+  created_at               timestamptz NOT NULL DEFAULT now(),
+  updated_at               timestamptz NOT NULL DEFAULT now()
+);
+
+COMMENT ON TABLE core.activation_state IS
+  'Canonical activation spine. One record per customer workspace. '
+  'Every screen reads from this — no scattered truth. '
+  'State machine: paid → provisioning → workspace_ready → connect_required → connected → first_event_seen → live.';
+
+ALTER TABLE core.activation_state ENABLE ROW LEVEL SECURITY;
+
+CREATE POLICY activation_state_service_all
+  ON core.activation_state FOR ALL TO service_role
+  USING (true) WITH CHECK (true);
+
+CREATE POLICY activation_state_auth_read
+  ON core.activation_state FOR SELECT TO authenticated
+  USING (core.is_member(workspace_id));
+
+CREATE POLICY activation_state_auth_update
+  ON core.activation_state FOR UPDATE TO authenticated
+  USING (core.is_member(workspace_id))
+  WITH CHECK (core.is_member(workspace_id));
+
+GRANT SELECT, UPDATE ON core.activation_state TO authenticated;
+GRANT ALL ON core.activation_state TO service_role;
+
+CREATE INDEX IF NOT EXISTS idx_activation_state_stripe_customer
+  ON core.activation_state(stripe_customer_id);
+
+CREATE INDEX IF NOT EXISTS idx_activation_state_next_action
+  ON core.activation_state(next_action);
+
+-- ------------------------------------
+-- 2. Auto-create activation record on workspace creation
+-- ------------------------------------
+
+CREATE OR REPLACE FUNCTION core.trg_create_activation_state()
+RETURNS trigger
+LANGUAGE plpgsql
+SECURITY DEFINER
+SET search_path = core, public
+AS $$
+BEGIN
+  INSERT INTO core.activation_state (workspace_id)
+  VALUES (NEW.id)
+  ON CONFLICT (workspace_id) DO NOTHING;
+  RETURN NEW;
+END;
+$$;
+
+DROP TRIGGER IF EXISTS trg_create_activation_state ON core.workspaces;
+CREATE TRIGGER trg_create_activation_state
+  AFTER INSERT ON core.workspaces
+  FOR EACH ROW
+  EXECUTE FUNCTION core.trg_create_activation_state();
+
+-- Backfill for existing workspaces
+INSERT INTO core.activation_state (workspace_id)
+SELECT id FROM core.workspaces
+WHERE id NOT IN (SELECT workspace_id FROM core.activation_state)
+ON CONFLICT (workspace_id) DO NOTHING;
+
+-- ------------------------------------
+-- 3. Contract resolver: resolve_activation_state
+-- ------------------------------------
+
+CREATE OR REPLACE FUNCTION api.resolve_activation_state(
+  p_workspace_id uuid
+)
+RETURNS jsonb
+LANGUAGE plpgsql
+SECURITY DEFINER
+SET search_path = core, ledger, registry, public
+AS $$
+DECLARE
+  v_state    core.activation_state%ROWTYPE;
+  v_ws       core.workspaces%ROWTYPE;
+  v_tenant   core.tenants%ROWTYPE;
+  v_events   int;
+  v_open     int;
+  v_receipts int;
+  v_next     text;
+  v_enforce  text;
+BEGIN
+  -- Load activation state
+  SELECT * INTO v_state
+    FROM core.activation_state
+   WHERE workspace_id = p_workspace_id;
+
+  IF NOT FOUND THEN
+    -- Create on the fly for workspaces without one
+    INSERT INTO core.activation_state (workspace_id)
+    VALUES (p_workspace_id)
+    ON CONFLICT (workspace_id) DO NOTHING;
+
+    SELECT * INTO v_state
+      FROM core.activation_state
+     WHERE workspace_id = p_workspace_id;
+  END IF;
+
+  -- Load workspace + tenant
+  SELECT * INTO v_ws FROM core.workspaces WHERE id = p_workspace_id;
+  SELECT * INTO v_tenant FROM core.tenants WHERE id = v_ws.tenant_id;
+
+  -- Compute live counts
+  SELECT count(*) INTO v_events
+    FROM ledger.events e
+   WHERE e.workspace_id = p_workspace_id;
+
+  SELECT count(*) INTO v_open
+    FROM core.obligations o
+   WHERE o.workspace_id = p_workspace_id
+     AND o.state = 'open';
+
+  SELECT count(*) INTO v_receipts
+    FROM ledger.receipts r
+   WHERE r.workspace_id = p_workspace_id;
+
+  -- Derive enforcement status from actual data
+  IF v_events > 0 AND v_open > 0 AND v_receipts > 0 THEN
+    v_enforce := 'live';
+  ELSIF v_events > 0 THEN
+    v_enforce := 'first_event_seen';
+  ELSE
+    v_enforce := v_state.enforcement_status;
+  END IF;
+
+  -- Derive next_action from current state
+  IF v_state.provisioning_status NOT IN ('workspace_ready') THEN
+    v_next := 'provisioning';
+  ELSIF v_state.stripe_connection_status = 'not_connected' THEN
+    v_next := 'connect_stripe';
+  ELSIF v_enforce IN ('not_live') THEN
+    v_next := 'wait_for_first_event';
+  ELSE
+    v_next := 'open_dashboard';
+  END IF;
+
+  -- Persist computed state back
+  UPDATE core.activation_state
+     SET events_received    = v_events,
+         obligations_open   = v_open,
+         receipts_issued    = v_receipts,
+         enforcement_status = v_enforce,
+         next_action        = v_next,
+         first_event_at     = CASE
+           WHEN v_events > 0 AND first_event_at IS NULL THEN now()
+           ELSE first_event_at
+         END,
+         activated_at       = CASE
+           WHEN v_enforce = 'live' AND activated_at IS NULL THEN now()
+           ELSE activated_at
+         END,
+         updated_at         = now()
+   WHERE workspace_id = p_workspace_id;
+
+  -- Return canonical activation object
+  RETURN jsonb_build_object(
+    'subscription',             v_state.subscription_status,
+    'billing_status',           v_state.billing_status,
+    'plan',                     v_state.plan_key,
+    'engine',                   v_state.engine_key,
+    'entitlement',              v_state.entitlement_key,
+    'governance',               v_state.governance_key,
+    'provisioning_status',      v_state.provisioning_status,
+    'workspace',                jsonb_build_object(
+      'id',   p_workspace_id,
+      'slug', v_ws.slug,
+      'name', COALESCE(v_state.business_name, v_ws.name)
+    ),
+    'membership_status',        v_state.membership_status,
+    'stripe_connection_status', v_state.stripe_connection_status,
+    'enforcement_status',       v_enforce,
+    'events_received',          v_events,
+    'obligations_open',         v_open,
+    'receipts_issued',          v_receipts,
+    'next_action',              v_next,
+    'business_name',            v_state.business_name,
+    'business_type',            v_state.business_type,
+    'first_event_at',           v_state.first_event_at,
+    'activated_at',             v_state.activated_at
+  );
+END;
+$$;
+
+COMMENT ON FUNCTION api.resolve_activation_state IS
+  'Contract resolver. Returns the canonical activation object for a workspace. '
+  'Computes live counts, derives enforcement_status and next_action, persists back. '
+  'This is the single source of truth for all UI routing.';
+
+GRANT EXECUTE ON FUNCTION api.resolve_activation_state(uuid) TO authenticated, service_role;
+
+-- ------------------------------------
+-- 4. Profile update RPC
+-- ------------------------------------
+
+CREATE OR REPLACE FUNCTION api.update_workspace_profile(
+  p_workspace_id  uuid,
+  p_business_name text,
+  p_business_type text DEFAULT NULL
+)
+RETURNS jsonb
+LANGUAGE plpgsql
+SECURITY DEFINER
+SET search_path = core, api, public
+AS $$
+BEGIN
+  PERFORM core.assert_member(p_workspace_id);
+
+  UPDATE core.activation_state
+     SET business_name = p_business_name,
+         business_type = COALESCE(p_business_type, business_type),
+         updated_at    = now()
+   WHERE workspace_id = p_workspace_id;
+
+  UPDATE core.workspaces
+     SET name = p_business_name || ' Operations'
+   WHERE id = p_workspace_id;
+
+  RETURN api.resolve_activation_state(p_workspace_id);
+END;
+$$;
+
+GRANT EXECUTE ON FUNCTION api.update_workspace_profile(uuid, text, text) TO authenticated, service_role;
+
+-- ------------------------------------
+-- 5. Stripe Connect recording
+-- ------------------------------------
+
+CREATE OR REPLACE FUNCTION api.record_stripe_connect(
+  p_workspace_id              uuid,
+  p_stripe_connect_account_id text
+)
+RETURNS jsonb
+LANGUAGE plpgsql
+SECURITY DEFINER
+SET search_path = core, api, public
+AS $$
+BEGIN
+  PERFORM core.assert_member(p_workspace_id);
+
+  UPDATE core.activation_state
+     SET stripe_connect_account_id  = p_stripe_connect_account_id,
+         stripe_connection_status   = 'connected',
+         updated_at                 = now()
+   WHERE workspace_id = p_workspace_id;
+
+  -- Register provider connection for ingest routing
+  INSERT INTO core.provider_connections (
+    workspace_id, provider, provider_account_id, livemode, is_active
+  ) VALUES (
+    p_workspace_id, 'stripe', p_stripe_connect_account_id, true, true
+  )
+  ON CONFLICT DO NOTHING;
+
+  RETURN api.resolve_activation_state(p_workspace_id);
+END;
+$$;
+
+GRANT EXECUTE ON FUNCTION api.record_stripe_connect(uuid, text) TO authenticated, service_role;
+
+-- ------------------------------------
+-- 6. Provisioning hook: set activation state on workspace provision
+-- ------------------------------------
+
+CREATE OR REPLACE FUNCTION api.activate_provisioned_workspace(
+  p_workspace_id         uuid,
+  p_stripe_customer_id   text,
+  p_stripe_subscription_id text DEFAULT NULL,
+  p_email                text DEFAULT NULL
+)
+RETURNS jsonb
+LANGUAGE plpgsql
+SECURITY DEFINER
+SET search_path = core, api, public
+AS $$
+BEGIN
+  UPDATE core.activation_state
+     SET stripe_customer_id      = p_stripe_customer_id,
+         stripe_subscription_id  = p_stripe_subscription_id,
+         subscription_status     = 'active',
+         billing_status          = 'paid',
+         provisioning_status     = 'workspace_ready',
+         membership_status       = 'active',
+         next_action             = 'connect_stripe',
+         updated_at              = now()
+   WHERE workspace_id = p_workspace_id;
+
+  RETURN api.resolve_activation_state(p_workspace_id);
+END;
+$$;
+
+GRANT EXECUTE ON FUNCTION api.activate_provisioned_workspace(uuid, text, text, text) TO service_role;
+
+COMMIT;

@@ -0,0 +1,39 @@
+import { NextRequest, NextResponse } from "next/server";
+import { requireOperatorRouteContext } from "@/lib/operator-access";
+
+export async function POST(req: NextRequest) {
+  const access = await requireOperatorRouteContext();
+  if (!access.ok) return access.response;
+
+  const { supabase, defaultWorkspaceId } = access.context;
+
+  try {
+    const body = await req.json();
+    const businessName = body.business_name;
+    const businessType = body.business_type ?? null;
+
+    if (!businessName || typeof businessName !== "string") {
+      return NextResponse.json(
+        { error: "business_name is required" },
+        { status: 400 }
+      );
+    }
+
+    const { data, error } = await supabase
+      .schema("api")
+      .rpc("update_workspace_profile", {
+        p_workspace_id: defaultWorkspaceId,
+        p_business_name: businessName.trim(),
+        p_business_type: businessType,
+      });
+
+    if (error) {
+      return NextResponse.json({ error: error.message }, { status: 500 });
+    }
+
+    return NextResponse.json(data);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : "Unknown error";
+    return NextResponse.json({ error: msg }, { status: 500 });
+  }
+}

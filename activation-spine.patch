+                <AkInput
+                  value={editName}
+                  onChange={setEditName}
+                  placeholder="Business name"
+                  className="max-w-sm"
+                />
+                <AkButton
+                  onClick={handleSave}
+                  disabled={saving || !editName.trim()}
+                  variant="ghost"
+                >
+                  {saving ? (
+                    <Loader2 className="h-4 w-4 animate-spin" />
+                  ) : (
+                    <Save className="h-4 w-4" />
+                  )}
+                </AkButton>
+              </div>
+              {saveMsg && (
+                <div className="mt-2 text-xs text-emerald-400">{saveMsg}</div>
+              )}
+            </div>
+          </div>
+
+          {summary.business_type && (
+            <div className="flex items-center gap-3">
+              <Shield className="h-5 w-5 text-slate-500" />
+              <div>
+                <div className="text-[10px] uppercase tracking-[0.2em] text-slate-500">
+                  Business Type
+                </div>
+                <div className="mt-1 text-sm text-slate-300">
+                  {summary.business_type.replace(/_/g, " ")}
+                </div>
+              </div>
+            </div>
+          )}
+        </div>
+      </AkPanel>
+
+      {/* Workspace Status */}
+      <AkPanel className="p-6">
+        <AkSectionHeader label="Workspace Status" />
+        <div className="mt-5 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
+          <div>
+            <div className="text-[10px] uppercase tracking-[0.2em] text-slate-500">
+              Onboarding
+            </div>
+            <div className="mt-2">{stateBadge(summary.onboarding_state)}</div>
+          </div>
+          <div>
+            <div className="text-[10px] uppercase tracking-[0.2em] text-slate-500">
+              Members
+            </div>
+            <div className="mt-2 flex items-center gap-2">
+              <Users className="h-4 w-4 text-slate-400" />
+              <span className="text-lg font-semibold text-white">
+                {summary.member_count}
+              </span>
+            </div>
+          </div>
+          <div>
+            <div className="text-[10px] uppercase tracking-[0.2em] text-slate-500">
+              Billing Provider
+            </div>
+            <div className="mt-2 flex items-center gap-2">
+              <CreditCard className="h-4 w-4 text-slate-400" />
+              <span className="text-sm text-slate-300">
+                {summary.stripe_connect_account_id
+                  ? "Stripe Connected"
+                  : "Not connected"}
+              </span>
+            </div>
+          </div>
+          <div>
+            <div className="text-[10px] uppercase tracking-[0.2em] text-slate-500">

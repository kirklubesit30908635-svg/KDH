+interface WorkspaceSummary {
+  workspace_id: string;
+  workspace_name: string;
+  workspace_slug: string;
+  tenant_name: string;
+  business_name: string | null;
+  business_type: string | null;
+  onboarding_state: string;
+  stripe_connect_account_id: string | null;
+  onboarded_at: string | null;
+  first_event_at: string | null;
+  open_obligations: number;
+  resolved_obligations: number;
+  total_obligations: number;
+  member_count: number;
+  receipt_count: number;
+}
+
+function stateBadge(state: string) {
+  switch (state) {
+    case "active":
+      return <AkBadge color="#34d399">Active</AkBadge>;
+    case "pending":
+      return <AkBadge tone="gold">Pending Setup</AkBadge>;
+    case "profile_complete":
+      return <AkBadge tone="gold">Profile Done</AkBadge>;
+    case "provider_connected":
+      return <AkBadge color="#60a5fa">Provider Connected</AkBadge>;
+    case "suspended":
+      return <AkBadge tone="danger">Suspended</AkBadge>;
+    default:
+      return <AkBadge tone="muted">{state}</AkBadge>;
+  }
+}
+
+export default function SettingsPage() {
+  const [summary, setSummary] = useState<WorkspaceSummary | null>(null);
+  const [loading, setLoading] = useState(true);
+  const [error, setError] = useState<string | null>(null);
+  const [editName, setEditName] = useState("");
+  const [saving, setSaving] = useState(false);
+  const [saveMsg, setSaveMsg] = useState<string | null>(null);
+
+  const loadSummary = useCallback(async () => {
+    setLoading(true);
+    try {
+      const res = await fetch("/api/customer/status", { cache: "no-store" });
+      const data = await res.json();
+      if (!res.ok) throw new Error(data.error);
+      const a = data.activation;
+      setSummary({
+        workspace_id: a.workspace?.id ?? "",
+        workspace_name: a.workspace?.name ?? "",
+        workspace_slug: a.workspace?.slug ?? "",
+        tenant_name: a.workspace?.name ?? "",
+        business_name: a.business_name,
+        business_type: a.business_type,
+        onboarding_state: a.next_action === "open_dashboard" ? "active" : a.next_action,
+        stripe_connect_account_id: a.stripe_connection_status === "connected" ? "connected" : null,
+        onboarded_at: a.activated_at,
+        first_event_at: a.first_event_at,
+        open_obligations: a.obligations_open ?? 0,
+        resolved_obligations: 0,
+        total_obligations: a.obligations_open ?? 0,
+        member_count: 0,
+        receipt_count: a.receipts_issued ?? 0,
+      });
+      setEditName(a.business_name ?? a.workspace?.name ?? "");
+    } catch (err) {
+      setError(err instanceof Error ? err.message : "Load failed");
+    } finally {
+      setLoading(false);
+    }
+  }, []);
+
+  useEffect(() => {
+    void loadSummary();
+  }, [loadSummary]);
+
+  async function handleSave() {
+    if (!editName.trim()) return;
+    setSaving(true);
+    setSaveMsg(null);
+    try {
+      const res = await fetch("/api/onboard/profile", {
+        method: "POST",
+        headers: { "Content-Type": "application/json" },
+        body: JSON.stringify({ business_name: editName.trim() }),
+      });
+      const data = await res.json();
+      if (!res.ok) throw new Error(data.error);
+      setSaveMsg("Saved");
+      void loadSummary();
+    } catch (err) {
+      setSaveMsg(err instanceof Error ? err.message : "Save failed");
+    } finally {
+      setSaving(false);
+    }
+  }
+
+  if (loading) {
+    return (
+      <AkShell title="Settings" eyebrow="Workspace Configuration">
+        <div className="flex items-center justify-center py-16">
